
@{
    ViewData["Title"] = "Employee Management";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        background: #f4f7fc;
    }

    .page-title {
        color: #0d6efd;
        font-weight: bold;
    }

    .card {
        border: none;
        border-radius: 12px;
    }

    .table thead {
        background: #0d6efd;
        color: white;
    }

    .btn-action {
        margin: 2px;
    }

    .search-box {
        max-width: 300px;
    }
</style>

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="page-title">Employee Management</h2>

        <button class="btn btn-success">
            + Add Employee
        </button>
    </div>

    <div class="card shadow-lg">

        <div class="card-body">

            <div class="row mb-3">

                <div class="col-md-4">
                    <input type="text"
                           class="form-control search-box"
                           placeholder="Search Employee...">
                </div>

            </div>

            <table class="table table-bordered table-hover align-middle text-center">

                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Department</th>
                        <th>Email</th>
                        <th>Salary</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>

                    <tr>
                        <td>101</td>
                        <td>John</td>
                        <td>IT</td>
                        <td>john@gmail.com</td>
                        <td>₹50,000</td>
                        <td>
                            <button class="btn btn-warning btn-sm btn-action">Edit</button>
                            <button class="btn btn-info btn-sm text-white btn-action">View</button>
                            <button class="btn btn-danger btn-sm btn-action">Delete</button>
                        </td>
                    </tr>

                    <tr>
                        <td>102</td>
                        <td>David</td>
                        <td>HR</td>
                        <td>david@gmail.com</td>
                        <td>₹45,000</td>
                        <td>
                            <button class="btn btn-warning btn-sm btn-action">Edit</button>
                            <button class="btn btn-info btn-sm text-white btn-action">View</button>
                            <button class="btn btn-danger btn-sm btn-action">Delete</button>
                        </td>
                    </tr>

                    <tr>
                        <td>103</td>
                        <td>Emma</td>
                        <td>Finance</td>
                        <td>emma@gmail.com</td>
                        <td>₹60,000</td>
                        <td>
                            <button class="btn btn-warning btn-sm btn-action">Edit</button>
                            <button class="btn btn-info btn-sm text-white btn-action">View</button>
                            <button class="btn btn-danger btn-sm btn-action">Delete</button>
                        </td>
                    </tr>

                </tbody>

            </table>

        </div>

    </div>

</div>